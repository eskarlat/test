{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://renre-kit.dev/schemas/config.json",
  "title": "RenRe Kit Config",
  "type": "object",
  "properties": {
    "port": { "type": "integer", "minimum": 1024, "maximum": 65535, "default": 42888 },
    "logLevel": { "type": "string", "enum": ["error", "warn", "info", "debug"], "default": "info" },
    "marketplaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      }
    },
    "backup": {
      "type": "object",
      "properties": {
        "intervalHours": { "type": "integer", "minimum": 1, "default": 24 },
        "maxCount": { "type": "integer", "minimum": 1, "default": 10 },
        "maxAgeDays": { "type": "integer", "minimum": 1, "default": 30 }
      }
    }
  }
}
